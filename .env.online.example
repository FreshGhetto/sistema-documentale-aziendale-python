APP_NAME=Sistema Documentale Aziendale
APP_ENV=production
SECRET_KEY=change-me-with-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Esempio MongoDB online Atlas/DigitalOcean.
# Non committare mai credenziali reali nel repository.
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER_HOST/DATABASE_NAME?retryWrites=true&w=majority
MONGO_DB_NAME=document_management

SOLR_URL=http://localhost:8983/solr/documents
SOLR_TIMEOUT_SECONDS=10

STORAGE_PATH=storage

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123!

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
